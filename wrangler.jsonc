/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "edge-llm-relay",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-07",
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"invocation_logs": true
		}
	},
	"placement": {  "mode": "smart" },
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	// Environment-specific configurations
	"env": {
		"baidu": {
			"name": "llmgateway",
			"placement": {
				"host": "qianfan.baidubce.com:443"
			},
			"vars": {
				"ROUTE_PREFIX": "baidu",
				"MODELS_ENABLED": "true",
				"UPSTREAM_BASE_URL": "https://qianfan.baidubce.com/v2/coding",
				"ANTHROPIC_UPSTREAM_BASE_URL": "https://qianfan.baidubce.com/anthropic/coding",
				"MODELS_JSON": "[{\"id\":\"ernie-4.5-turbo-20260402\"},{\"id\":\"minimax-m2.5\"},{\"id\":\"deepseek-v3.2\"},{\"id\":\"glm-5\"},{\"id\":\"kimi-k2.5\"}]"
			}
		},
		"jd": {
			"name": "llmgateway-jd",
			"placement": {
				"host": "modelservice.jdcloud.com:443"
			},
			"vars": {
				"ROUTE_PREFIX": "jd",
				"MODELS_ENABLED": "true",
				"UPSTREAM_BASE_URL": "https://modelservice.jdcloud.com/coding/openai/v1",
				"ANTHROPIC_UPSTREAM_BASE_URL": "https://modelservice.jdcloud.com/coding/anthropic",
				"MODELS_JSON": "[{\"id\":\"GLM-4.7\"},{\"id\":\"MiniMax-M2.5\"},{\"id\":\"deepseek-v3.2\"},{\"id\":\"GLM-5\"},{\"id\":\"kimi-k2.5\"},{\"id\":\"Qwen3-Coder\"},{\"id\":\"Kimi-K2-Turbo\"}]"
			}
		},
		"minimax": {
			"name": "llmgateway-minimax",
			"placement": {
				"host": "api.minimaxi.com:443"
			},
			"vars": {
				"ROUTE_PREFIX": "minimax",
				"MODELS_ENABLED": "true",
				"UPSTREAM_BASE_URL": "https://api.minimaxi.com/v1",
				"ANTHROPIC_UPSTREAM_BASE_URL": "https://api.minimaxi.com/anthropic",
				"MODELS_JSON": "[{\"id\":\"minimax-m2.5\"},{\"id\":\"minimax-text-01\"}]"
			}
		}
	}
}
